[Unit]
Description=Lazynext Infrastructure (PostgreSQL + Redis via Docker Compose)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/lazynext/infra/linode
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
StandardOutput=append:/var/log/lazynext/infra.log
StandardError=append:/var/log/lazynext/infra-error.log

[Install]
WantedBy=multi-user.target
