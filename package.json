{
  "name": "lazynext",
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "packages/*",
    "rust/wasm/pkg"
  ],
  "scripts": {
    "build:tools": "turbo run build --filter=@lazynext/tools",
    "build:wasm": "wasm-pack build rust/wasm --target bundler --out-dir pkg",
    "build:web": "turbo run build --filter=@lazynext/web",
    "deploy:web": "turbo run deploy --filter=@lazynext/web",
    "dev:tools": "turbo run dev --filter=@lazynext/tools",
    "dev:wasm": "cargo watch -w rust/crates -w rust/wasm/src -s 'wasm-pack build rust/wasm --target bundler --out-dir pkg'",
    "dev:web": "turbo run dev --filter=@lazynext/web",
    "format:web": "prettier apps/web/src/services/renderer --write",
    "generate:fonts": "npx tsx apps/web/scripts/generate-font-sprites.ts",
    "lint:web": "eslint apps/web/src --ext .ts,.tsx",
    "lint:web:fix": "eslint apps/web/src --ext .ts,.tsx --fix",
    "preview:web": "turbo run preview --filter=@lazynext/web",
    "publish:wasm": "bun run build:wasm && npm publish rust/wasm/pkg --access public",
    "start:tools": "turbo run start --filter=@lazynext/tools",
    "test": "bun test",
    "e2e": "turbo run e2e --filter=@lazynext/web"
  },
  "dependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.6.14",
    "next": "^16.2.7",
    "lazynext": ".",
    "lazynext-wasm": "^0.2.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
