{
  "name": "lazynext-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "rust/wasm/pkg"
  ],
  "scripts": {
    "dev": "bun run --filter \"@lazynext/*\" dev",
    "build": "bun run --filter \"@lazynext/*\" build",
    "lint": "bun run --filter \"@lazynext/*\" lint",
    "test": "bun run --filter \"@lazynext/*\" test",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "typescript": "^5.9.3",
    "prettier": "^3.0.0",
    "eslint": "^9.0.0"
  }
}
