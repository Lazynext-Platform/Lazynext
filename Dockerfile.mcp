# LEGACY — Prefer service-specific Dockerfiles in services/*/Dockerfile
# Build stage
FROM rust:1-slim-bullseye AS builder

WORKDIR /usr/src/lazynext

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

# Copy entire workspace
COPY Cargo.toml Cargo.lock ./
COPY rust/ ./rust/
COPY apps/ ./apps/

# Build the mcp-server binary
RUN cargo build --release --bin lazynext_mcp_server

# Production stage
FROM debian:bullseye-slim AS runner
WORKDIR /usr/local/bin

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/src/lazynext/target/release/lazynext_mcp_server .

# MCP Server operates over stdio, not HTTP.
CMD ["./lazynext_mcp_server"]
