# ── Lazynext Production Env — Linode ─────────────────────────────
# Copy to .env.production and fill in actual values:
#   cp .env.production.example .env.production
#
# ⚠️  NEVER commit .env.production to version control.
# ⚠️  Generate secrets with: openssl rand -base64 64
#
# Deployed at: 192.46.209.127 (Linode 8GB, Mumbai)
# See: infra/linode/README.md for deployment instructions.

# ═══════════════════════════════════════════════════════════════════
# PROJECT IDENTITY
# ═══════════════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=lazynext-prod
ENVIRONMENT=production
DOMAIN=lazynext.com

# ═══════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL 17
# ═══════════════════════════════════════════════════════════════════
DB_USER=lazynext
DB_PASSWORD=                                 # Generate: openssl rand -base64 32
DB_NAME=lazynext
DATABASE_URL=postgresql://lazynext:${DB_PASSWORD}@127.0.0.1:5432/lazynext

# ═══════════════════════════════════════════════════════════════════
# REDIS 7
# ═══════════════════════════════════════════════════════════════════
REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_REST_TOKEN=                    # Generate: openssl rand -base64 32

# ═══════════════════════════════════════════════════════════════════
# AUTHENTICATION — Better Auth (HS256 JWT)
# ═══════════════════════════════════════════════════════════════════
BETTER_AUTH_SECRET=                          # Generate: openssl rand -base64 64
BETTER_AUTH_URL=https://lazynext.com

# ═══════════════════════════════════════════════════════════════════
# PAYMENTS — Dodo Payments
# ═══════════════════════════════════════════════════════════════════
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
NEXT_PUBLIC_DODO_PRO_PRICE_ID=pro_monthly
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID=studio_monthly
NEXT_PUBLIC_DODO_PRO_PRICE_ID_LIVE=
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID_LIVE=

# ═══════════════════════════════════════════════════════════════════
# EMAIL — Resend
# ═══════════════════════════════════════════════════════════════════
RESEND_API_KEY=
EMAIL_FROM="Lazynext <no-reply@lazynext.com>"

# ═══════════════════════════════════════════════════════════════════
# AI PROVIDERS — At least one required
#   Get keys from:
#     OpenAI:    https://platform.openai.com/api-keys
#     Anthropic: https://console.anthropic.com/settings/keys
#     Gemini:    https://aistudio.google.com/apikey
# ═══════════════════════════════════════════════════════════════════
LLM_PROVIDER=anthropic                       # openai | anthropic | gemini | ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# VIDEO AI — Fal.ai + Kling 3.0 (best quality/price)
#   Get your key at: https://fal.ai/dashboard/keys
#   Default model: Kling 3.0 Standard text-to-video
# ═══════════════════════════════════════════════════════════════════
FAL_KEY=
# FAL_VIDEO_MODEL=fal-ai/kling-video/o3/standard/text-to-video
# FAL_INPAINT_MODEL=fal-ai/propainter

# ═══════════════════════════════════════════════════════════════════
# STORAGE — Local filesystem (Linode)
# ═══════════════════════════════════════════════════════════════════
STORAGE_PROVIDER=local
MEDIA_BUCKET=lazynext-media-prod

# ═══════════════════════════════════════════════════════════════════
# SERVICE URLs
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=https://lazynext.com
NEXT_PUBLIC_PREPROCESSING_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GENERATIVE_STUDIO_URL=http://127.0.0.1:8001
NEXT_PUBLIC_AI_AGENTS_URL=http://127.0.0.1:8002
NEXT_PUBLIC_RENDER_SERVICE_URL=http://127.0.0.1:8003
NEXT_PUBLIC_SOCIAL_PUBLISH_URL=http://127.0.0.1:8007
NEXT_PUBLIC_SYNC_SERVER_URL=wss://collab.lazynext.com/ws
API_GATEWAY_URL=https://api.lazynext.com

# ═══════════════════════════════════════════════════════════════════
# MCP / INTERNAL API
# ═══════════════════════════════════════════════════════════════════
LAZYNEXT_MCP_API_KEY=                        # Generate: openssl rand -base64 32
INTERNAL_API_KEY=                            # Generate: openssl rand -base64 32
LAZYNEXT_WEBHOOK_URL=https://lazynext.com/api/webhooks

# ═══════════════════════════════════════════════════════════════════
# CMS / AUDIO LIBRARY
#   Marble CMS: https://app.marblecms.com/settings
#   Freesound:  https://freesound.org/apiv2/apply
# ═══════════════════════════════════════════════════════════════════
MARBLE_WORKSPACE_KEY=
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com
FREESOUND_CLIENT_ID=
FREESOUND_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# SOCIAL PUBLISH — YouTube, TikTok, Instagram, Twitter/X
#   YouTube:   https://console.cloud.google.com/apis/credentials
#   TikTok:    https://developers.tiktok.com/apps
#   Instagram: https://developers.facebook.com/apps
#   Twitter/X: https://developer.x.com/en/portal/dashboard
# ═══════════════════════════════════════════════════════════════════
YT_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
PUBLIC_MEDIA_BASE_URL=https://media.lazynext.com

# ═══════════════════════════════════════════════════════════════════
# ANALYTICS — PostHog
#   https://app.posthog.com/settings/project
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ═══════════════════════════════════════════════════════════════════
# OBSERVABILITY (optional — only for monitoring stack)
# ═══════════════════════════════════════════════════════════════════
GRAFANA_ADMIN_PASSWORD=
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
