# ── Lazynext Production Environment Variables ────────────────────
# Copy to .env.production and fill in actual values:
#   cp .env.production.example .env.production
#
# ⚠️  NEVER commit .env.production to version control.
# ⚠️  Sensitive values (API keys, passwords) should use Docker secrets
#     in production. Variables suffixed with _FILE indicate the path
#     to a Docker secret containing the actual value.
#
# See: docs/production-runbook.md for full variable reference.

# ═══════════════════════════════════════════════════════════════
# PROJECT IDENTITY
# ═══════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=lazynext-prod
COMPOSE_FILE=docker-compose.prod-full.yml
DOMAIN=lazynext.com
ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL 16
# ═══════════════════════════════════════════════════════════════

DB_USER=lazynext
DB_PASSWORD=                            # Set via Docker secret: lazynext_postgres_password
DATABASE_URL=postgresql://lazynext:${DB_PASSWORD}@postgres:5432/lazynext
POSTGRES_DB=lazynext
# For Azure-hosted PostgreSQL, set:
# AZURE_POSTGRES_HOST=lazynext-prod.postgres.database.azure.com
# AZURE_POSTGRES_USER=lazynext@lazynext-prod

# ═══════════════════════════════════════════════════════════════
# REDIS 7
# ═══════════════════════════════════════════════════════════════

REDIS_PASSWORD=                         # Set via Docker secret or direct var
# Redis URL per-service (constructed in compose, no env needed)

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION — Better Auth
# ═══════════════════════════════════════════════════════════════

BETTER_AUTH_SECRET=                     # Set via Docker secret: lazynext_better_auth_secret
                                        # Generate: openssl rand -base64 64
BETTER_AUTH_URL=https://lazynext.com

# ═══════════════════════════════════════════════════════════════
# DODO PAYMENTS — Payments
# ═══════════════════════════════════════════════════════════════

DODO_API_KEY=                           # Set via Docker secret: lazynext_dodo_api_key
DODO_WEBHOOK_SECRET=                    # Set via Docker secret: lazynext_dodo_webhook_secret
NEXT_PUBLIC_DODO_PRO_PRICE_ID=pro_monthly
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID=studio_monthly

# ═══════════════════════════════════════════════════════════════
# EMAIL — Resend
# ═══════════════════════════════════════════════════════════════

RESEND_API_KEY=                         # Set via Docker secret: lazynext_resend_api_key

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════════════

LLM_PROVIDER=anthropic                  # openai | anthropic | gemini | ollama
OPENAI_API_KEY=                         # Set via Docker secret: lazynext_openai_api_key
ANTHROPIC_API_KEY=                      # Set via Docker secret: lazynext_anthropic_api_key
GEMINI_API_KEY=                         # Set via Docker secret: lazynext_gemini_api_key

# ═══════════════════════════════════════════════════════════════
# EXTERNAL AI SERVICES
# ═══════════════════════════════════════════════════════════════

REPLICATE_API_TOKEN=                    # Set via Docker secret: lazynext_replicate_api_token
ELEVENLABS_API_KEY=                     # Set via Docker secret: lazynext_elevenlabs_api_key

# ═══════════════════════════════════════════════════════════════
# STORAGE — Azure Blob
# ═══════════════════════════════════════════════════════════════

STORAGE_PROVIDER=azure                  # azure | local | s3
MEDIA_BUCKET=lazynext-media-prod
AZURE_STORAGE_ACCOUNT=lazynextmediaprod
AZURE_STORAGE_CONNECTION_STRING=        # Set via environment or Azure Managed Identity

# ═══════════════════════════════════════════════════════════════
# MARBLE CMS
# ═══════════════════════════════════════════════════════════════

MARBLE_WORKSPACE_KEY=                   # Set via Docker secret: lazynext_marble_workspace_key

# ═══════════════════════════════════════════════════════════════
# FREESOUND — Audio Library
# ═══════════════════════════════════════════════════════════════

FREESOUND_CLIENT_ID=                    # Set via Docker secret: lazynext_freesound_client_id
FREESOUND_API_KEY=                      # Set via Docker secret: lazynext_freesound_api_key

# ═══════════════════════════════════════════════════════════════
# SOCIAL PUBLISH — YouTube, TikTok, Instagram, Twitter/X
# ═══════════════════════════════════════════════════════════════

YT_CLIENT_ID=
TIKTOK_CLIENT_KEY=

# ═══════════════════════════════════════════════════════════════
# ANALYTICS — PostHog
# ═══════════════════════════════════════════════════════════════

POSTHOG_KEY=phc_prod_xxx

# ═══════════════════════════════════════════════════════════════
# MCP / API GATEWAY
# ═══════════════════════════════════════════════════════════════

LAZYNEXT_MCP_API_KEY=                   # Set via Docker secret: lazynext_mcp_api_key
LAZYNEXT_WEBHOOK_URL=
API_GATEWAY_URL=https://api.lazynext.com/v1

# ═══════════════════════════════════════════════════════════════
# RENDER SERVICE
# ═══════════════════════════════════════════════════════════════

RENDER_PARALLELISM=4                    # Parallel FFmpeg jobs per worker

# ═══════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════

GRAFANA_ADMIN_PASSWORD=                 # Change immediately after first deploy
SLACK_WEBHOOK_URL=                      # For Alertmanager → Slack notifications
PAGERDUTY_INTEGRATION_KEY=              # For PagerDuty critical alerts
RESEND_ALERT_EMAIL_KEY=                 # For Alertmanager email notifications

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# ═══════════════════════════════════════════════════════════════
# TRAEFIK / SSL
# ═══════════════════════════════════════════════════════════════

CF_API_EMAIL=ops@lazynext.ai
CF_DNS_API_TOKEN=                       # Cloudflare API token with Zone:DNS:Edit
ACME_EMAIL=ops@lazynext.ai
LETSENCRYPT_STAGING=false               # Set true for testing to avoid rate limits
# LETSENCRYPT_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
LETSENCRYPT_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
TRAEFIK_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════

COLLAB_LOG_LEVEL=info
API_GATEWAY_LOG_LEVEL=info
