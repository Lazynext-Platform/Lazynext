;; ── PgBouncer {{ pgbouncer_version }} configuration ──────────────────
;; Managed by Ansible — do not edit by hand.

[databases]
; Application database via connection pool
lazynext = host=localhost port={{ postgresql_port }} dbname=lazynext pool_size={{ pgbouncer_default_pool_size }} reserve_pool={{ pgbouncer_reserve_pool_size }}

; Primary node alias — used when pgbouncer runs on replica nodes
; that need to route writes through the primary
{% if 'masters' in group_names %}
lazynext_primary = host=localhost port={{ postgresql_port }} dbname=lazynext pool_size={{ pgbouncer_default_pool_size }} reserve_pool={{ pgbouncer_reserve_pool_size }}
{% else %}
lazynext_primary = host={{ hostvars[groups['masters'][0]].ansible_host | default(groups['masters'][0]) }} port={{ postgresql_port }} dbname=lazynext pool_size={{ pgbouncer_default_pool_size }} reserve_pool={{ pgbouncer_reserve_pool_size }}
{% endif %}

; Read-only replica
{% if 'workers' in group_names and postgresql_standby_sync | default(false) | bool %}
lazynext_replica = host=localhost port={{ postgresql_port }} dbname=lazynext pool_size={{ pgbouncer_default_pool_size }} reserve_pool={{ pgbouncer_reserve_pool_size }}
{% endif %}

[pgbouncer]
;; ── Connection settings ──────────────────────────────────────────
listen_addr = 0.0.0.0
listen_port = {{ pgbouncer_listen_port }}
unix_socket_dir = /var/run/postgresql
auth_file = /etc/pgbouncer/userlist.txt
auth_type = scram-sha-256
admin_users = {{ postgresql_admin_user }}

;; ── Pooling settings ─────────────────────────────────────────────
pool_mode = {{ pgbouncer_pool_mode }}
max_client_conn = {{ pgbouncer_max_client_conn }}
default_pool_size = {{ pgbouncer_default_pool_size }}
reserve_pool_size = {{ pgbouncer_reserve_pool_size }}
reserve_pool_timeout = 3
server_reset_query = DISCARD ALL
server_check_query = SELECT 1
server_check_delay = 30
server_lifetime = 3600
server_idle_timeout = 600
server_connect_timeout = 15
server_login_retry = 15
client_login_timeout = 60
client_idle_timeout = 0
query_timeout = 0
query_wait_timeout = 120

;; ── Logging ──────────────────────────────────────────────────────
log_connections = 1
log_disconnections = 1
log_pooler_errors = 1
log_stats = 1
stats_period = 60
verbose = 0

;; ── Misc ─────────────────────────────────────────────────────────
application_name_add_host = 1
ignore_startup_parameters = extra_float_digits
disable_pqexec = 0
tcp_keepalive = 1
tcp_keepidle = 60
tcp_keepintvl = 10
tcp_keepcnt = 6
