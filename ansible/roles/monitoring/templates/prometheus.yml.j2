# ── Prometheus configuration ───────────────────────────────────────
# Managed by Ansible — do not edit by hand.

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  scrape_timeout: 10s
  external_labels:
{% for key, value in prometheus_external_labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}

# ── Alerting ──────────────────────────────────────────────────────
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "alertmanager:9093"
      scheme: http
      timeout: 10s
      api_version: v2

# ── Rules ─────────────────────────────────────────────────────────
rule_files:
  - "/etc/prometheus/rules/*.yml"

# ── Scrape configurations ─────────────────────────────────────────
scrape_configs:
  # ── Prometheus self-monitoring ──────────────────────────────────
  - job_name: prometheus
    static_configs:
      - targets:
          - "localhost:9090"
    metrics_path: /metrics

  # ── Node exporters on all hosts ─────────────────────────────────
  - job_name: node_exporter
    scrape_interval: 30s
    static_configs:
{% for host in groups['all'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9100"
        labels:
          hostname: "{{ host }}"
          role: "{{ hostvars[host].node_role | default('unknown') }}"
{% endfor %}

  # ── PostgreSQL exporters ────────────────────────────────────────
  - job_name: postgresql
    scrape_interval: 30s
    static_configs:
{% for host in groups['masters'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9187"
        labels:
          hostname: "{{ host }}"
          instance: "postgresql-primary"
{% endfor %}
{% for host in groups['workers'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9187"
        labels:
          hostname: "{{ host }}"
          instance: "postgresql-standby"
{% endfor %}

  # ── Redis exporters ─────────────────────────────────────────────
  - job_name: redis
    scrape_interval: 30s
    static_configs:
{% for host in groups['masters'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9121"
        labels:
          hostname: "{{ host }}"
          role: master
{% endfor %}
{% for host in groups['workers'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9121"
        labels:
          hostname: "{{ host }}"
          role: worker
{% endfor %}

  # ── Docker engine metrics ───────────────────────────────────────
  - job_name: docker
    scrape_interval: 30s
    static_configs:
{% for host in groups['all'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9323"
        labels:
          hostname: "{{ host }}"
{% endfor %}

  # ── Kubernetes cAdvisor / kubelet metrics ───────────────────────
  - job_name: kubernetes-nodes
    scrape_interval: 30s
    scheme: https
    tls_config:
      insecure_skip_verify: true
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    static_configs:
{% for host in groups['k8s'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:10250"
        labels:
          hostname: "{{ host }}"
{% endfor %}

  # ── Kubernetes API server ───────────────────────────────────────
  - job_name: kubernetes-apiservers
    scrape_interval: 30s
    scheme: https
    tls_config:
      insecure_skip_verify: true
    bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
    static_configs:
{% for host in groups['masters'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:6443"
{% endfor %}

  # ── NVIDIA DCGM exporter on GPU nodes ───────────────────────────
  - job_name: nvidia-dcgm
    scrape_interval: 30s
    static_configs:
{% for host in groups['gpu_nodes'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:9400"
        labels:
          hostname: "{{ host }}"
          accelerator: nvidia-gpu
{% endfor %}

  # ── Grafana Alloy agent ─────────────────────────────────────────
  - job_name: alloy
    scrape_interval: 30s
    static_configs:
{% for host in groups['masters'] %}
      - targets:
          - "{{ hostvars[host].ansible_host | default(host) }}:12345"
        labels:
          hostname: "{{ host }}"
{% endfor %}

  # ── Lazynext microservices (from K8s service discovery) ─────────
  - job_name: lazynext-services
    scrape_interval: 30s
    kubernetes_sd_configs:
      - role: endpoints
        api_server: "https://{{ hostvars[groups['masters'][0]].ansible_host | default(groups['masters'][0]) }}:6443"
        tls_config:
          insecure_skip_verify: true
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_annotation_prometheus_io_scrape]
        action: keep
        regex: "true"
      - source_labels: [__meta_kubernetes_service_annotation_prometheus_io_scheme]
        action: replace
        target_label: __scheme__
        regex: "(https?)"
      - source_labels: [__meta_kubernetes_service_annotation_prometheus_io_path]
        action: replace
        target_label: __metrics_path__
        regex: "(.+)"
      - source_labels:
          [__address__, __meta_kubernetes_service_annotation_prometheus_io_port]
        action: replace
        target_label: __address__
        regex: "([^:]+)(?::\\d+)?;(\\d+)"
        replacement: "$1:$2"
      - action: labelmap
        regex: "__meta_kubernetes_service_label_(.+)"
      - source_labels: [__meta_kubernetes_namespace]
        action: replace
        target_label: kubernetes_namespace
      - source_labels: [__meta_kubernetes_service_name]
        action: replace
        target_label: kubernetes_service_name
      - source_labels: [__meta_kubernetes_pod_node_name]
        action: replace
        target_label: kubernetes_pod_node_name
