# {{ ansible_managed }}
# Docker daemon configuration — deployed by Ansible docker role
{
  "log-driver": "{{ docker_log_driver | default('json-file') }}",
  "log-opts": {
    "max-size": "{{ docker_log_max_size | default('10m') }}",
    "max-file": "{{ docker_log_max_file | default('3') }}"
  },
  "storage-driver": "{{ docker_storage_driver | default('overlay2') }}",
  "live-restore": true,
  "metrics-addr": "0.0.0.0:9323",
  "experimental": false,
{% if 'gpu_nodes' in group_names %}
  "default-runtime": "nvidia",
  "runtimes": {
    "nvidia": {
      "path": "nvidia-container-runtime",
      "runtimeArgs": []
    }
  }
{% else %}
  "default-runtime": "runc"
{% endif %}
}
