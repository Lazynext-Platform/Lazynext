{
  "dashboard": {
    "uid": "lazynext-ml",
    "title": "Lazynext — ML Inference",
    "tags": ["lazynext", "ml", "gpu", "production"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": {
      "from": "now-3h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "GPU Utilization per Device",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "avg(ml_gpu_utilization_percent{device!=\"\"}) by (device)",
            "legendFormat": "{{device}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 30, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": ["mean"]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true,
          "orientation": "auto"
        }
      },
      {
        "id": 2,
        "title": "GPU Memory Used / Total",
        "type": "gauge",
        "gridPos": {"x": 4, "y": 0, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "avg(ml_gpu_memory_used_bytes{device!=\"\"}) by (device) / (1024 * 1024 * 1024)",
            "legendFormat": "{{device}} Used",
            "refId": "A"
          },
          {
            "expr": "avg(ml_gpu_memory_total_bytes{device!=\"\"}) by (device) / (1024 * 1024 * 1024)",
            "legendFormat": "{{device}} Total",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decgbytes",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.7, "color": "yellow"},
                {"value": 0.9, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "showThresholdLabels": true,
          "showThresholdMarkers": true,
          "orientation": "auto"
        }
      },
      {
        "id": 3,
        "title": "GPU Memory Bandwidth Utilization",
        "type": "stat",
        "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
        "targets": [
          {
            "expr": "avg(ml_gpu_memory_bandwidth_utilization_percent)",
            "legendFormat": "Bandwidth %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 60, "color": "yellow"},
                {"value": 85, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["mean"]},
          "colorMode": "value"
        }
      },
      {
        "id": 4,
        "title": "GPU Temperature",
        "type": "stat",
        "gridPos": {"x": 8, "y": 3, "w": 4, "h": 3},
        "targets": [
          {
            "expr": "avg(ml_gpu_temperature_celsius{device!=\"\"}) by (device)",
            "legendFormat": "{{device}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 65, "color": "yellow"},
                {"value": 80, "color": "orange"},
                {"value": 85, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["mean"]},
          "colorMode": "value"
        }
      },
      {
        "id": 5,
        "title": "Active ML Requests",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
        "targets": [
          {
            "expr": "sum(ml_inference_requests_in_flight)",
            "legendFormat": "In Flight",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 20, "color": "orange"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 6,
        "title": "ML Request Rate",
        "type": "stat",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3},
        "targets": [
          {
            "expr": "sum(rate(ml_inference_requests_total[5m]))",
            "legendFormat": "req/s",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 1, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 7,
        "title": "Inference Error Rate",
        "type": "stat",
        "gridPos": {"x": 20, "y": 0, "w": 4, "h": 3},
        "targets": [
          {
            "expr": "sum(rate(ml_inference_errors_total[5m])) / sum(rate(ml_inference_requests_total[5m])) * 100",
            "legendFormat": "Error %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 2, "color": "orange"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        }
      },
      {
        "id": 8,
        "title": "Inference Latency by Model (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 6, "w": 12, "h": 9},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(whisper_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Whisper p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(whisper_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Whisper p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(whisper_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Whisper p99",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(sam2_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "SAM2 p50",
            "refId": "D"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(sam2_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "SAM2 p95",
            "refId": "E"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(sam2_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "SAM2 p99",
            "refId": "F"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "spanNulls": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": "/.*p99/"},
              "properties": [
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [5, 3]}}
              ]
            },
            {
              "matcher": {"id": "byRegexp", "options": "/.*p95/"},
              "properties": [
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 3]}}
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 9,
        "title": "RealESRGAN / Stable Diffusion Latency (p95)",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 6, "w": 12, "h": 9},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(realesrgan_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "RealESRGAN p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(stable_diffusion_inference_duration_seconds_bucket[5m])) by (le, resolution))",
            "legendFormat": "SD {{resolution}} p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(demucs_inference_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Demucs p95",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 10,
        "title": "Inference Latency Heatmap by Model",
        "type": "heatmap",
        "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(whisper_inference_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{le}}s",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"scaleDistribution": {"type": "log"}}
          }
        },
        "options": {
          "calculate": true,
          "yAxis": {"format": "s"},
          "color": {"mode": "opacity", "exponent": 0.5}
        },
        "title": "Whisper Latency Heatmap"
      },
      {
        "id": 11,
        "title": "SAM2 Latency Heatmap",
        "type": "heatmap",
        "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(sam2_inference_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{le}}s",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"scaleDistribution": {"type": "log"}}
          }
        },
        "options": {
          "calculate": true,
          "yAxis": {"format": "s"},
          "color": {"mode": "opacity", "exponent": 0.5}
        }
      },
      {
        "id": 12,
        "title": "Model Warmup Status",
        "type": "stat",
        "gridPos": {"x": 0, "y": 23, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "ml_model_warmup_status",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            },
            "mappings": [
              {"type": "value", "value": "0", "text": "COLD"},
              {"type": "value", "value": "1", "text": "WARM"}
            ],
            "noValue": "UNKNOWN"
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "textMode": "auto",
          "orientation": "auto"
        }
      },
      {
        "id": 13,
        "title": "Inference Errors by Type",
        "type": "barchart",
        "gridPos": {"x": 4, "y": 23, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ml_inference_errors_total[15m])) by (error_type)",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "showValue": "auto",
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 14,
        "title": "Inference Errors by Model",
        "type": "barchart",
        "gridPos": {"x": 12, "y": 23, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ml_inference_errors_total[15m])) by (model)",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "orientation": "horizontal",
          "showValue": "auto",
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 15,
        "title": "External API Usage — Replicate",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 31, "w": 12, "h": 7},
        "targets": [
          {
            "expr": "sum(rate(replicate_api_requests_total[5m])) by (model)",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"}
        }
      },
      {
        "id": 16,
        "title": "External API Usage — ElevenLabs",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 31, "w": 12, "h": 7},
        "targets": [
          {
            "expr": "sum(rate(elevenlabs_api_requests_total[5m])) by (operation)",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"}
        }
      },
      {
        "id": 17,
        "title": "External API Latency (p95)",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 38, "w": 12, "h": 7},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(replicate_api_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Replicate p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(elevenlabs_api_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "ElevenLabs p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(openai_api_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "OpenAI p95",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 18,
        "title": "External API Rate Limit Hits",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 38, "w": 12, "h": 7},
        "targets": [
          {
            "expr": "sum(rate(external_api_rate_limit_hits_total[5m])) by (service)",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "cps",
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80
            },
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "transparent"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"}
        }
      },
      {
        "id": 19,
        "title": "Batch Size vs Latency Correlation",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 45, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ml_inference_duration_seconds_bucket[5m])) by (le, batch_size))",
            "legendFormat": "batch={{batch_size}} p95",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["mean", "max"]
          },
          "tooltip": {"mode": "multi", "sort": "asc"}
        }
      },
      {
        "id": 20,
        "title": "Inference Queue / Batch Distribution",
        "type": "barchart",
        "gridPos": {"x": 12, "y": 45, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(increase(ml_inference_requests_total[1h])) by (batch_size)",
            "legendFormat": "batch={{batch_size}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "orientation": "vertical",
          "showValue": "auto",
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "query",
          "label": "Environment",
          "query": "label_values(up, environment)",
          "multi": true,
          "includeAll": true,
          "current": {"text": "All", "value": "$__all"}
        },
        {
          "name": "model",
          "type": "query",
          "label": "Model",
          "query": "label_values(ml_inference_requests_total, model)",
          "multi": true,
          "includeAll": true,
          "current": {"text": "All", "value": "$__all"}
        },
        {
          "name": "gpu_device",
          "type": "query",
          "label": "GPU Device",
          "query": "label_values(ml_gpu_utilization_percent, device)",
          "multi": true,
          "includeAll": true,
          "current": {"text": "All", "value": "$__all"}
        }
      ]
    }
  }
}
