{
  "dashboard": {
    "uid": "lazynext-platform-overview",
    "title": "Lazynext — Platform Overview",
    "tags": ["lazynext", "production", "overview"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "15s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "All Services — Status",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 3},
        "targets": [
          {
            "expr": "up{job=~\"lazynext-.*\"}",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            },
            "mappings": [
              {"type": "value", "value": "0", "text": "DOWN"},
              {"type": "value", "value": "1", "text": "UP"}
            ]
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name",
          "orientation": "horizontal"
        }
      },
      {
        "id": 2,
        "title": "Total Request Rate (all services)",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[1m])) by (service)",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15,
              "spanNulls": true,
              "stacking": {"mode": "none"}
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 3,
        "title": "Error Rate by Service (5xx %)",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 3, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "spanNulls": true
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 4,
        "title": "P95 Latency by Service",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 11, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 5,
        "title": "P99 Latency by Service",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 11, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 6,
        "title": "API Gateway — Throughput (req/s)",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 19, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"lazynext-api-gateway\"}[1m]))",
            "legendFormat": "Throughput",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 10, "color": "green"},
                {"value": 100, "color": "yellow"},
                {"value": 500, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 7,
        "title": "Web App — Active Users",
        "type": "stat",
        "gridPos": {"x": 6, "y": 19, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "sum(websocket_connections_active{service=\"lazynext-web\"})",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 8,
        "title": "Collab Server — Active Sessions",
        "type": "stat",
        "gridPos": {"x": 12, "y": 19, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "sum(websocket_connections_active{service=\"lazynext-collab-server\"})",
            "legendFormat": "Sessions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 9,
        "title": "Database — Active Connections",
        "type": "gauge",
        "gridPos": {"x": 18, "y": 19, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "pg_stat_database_numbackends{datname=\"lazynext\"}",
            "legendFormat": "Connections",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 150, "color": "orange"},
                {"value": 180, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 10,
        "title": "Service Uptime (24h)",
        "type": "bargauge",
        "gridPos": {"x": 0, "y": 25, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "avg_over_time(up{job=~\"lazynext-.*\"}[24h]) * 100",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 95, "color": "yellow"},
                {"value": 99.9, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "orientation": "horizontal",
          "displayMode": "lcd",
          "showUnfilled": true
        }
      },
      {
        "id": 11,
        "title": "HTTP Status Code Distribution",
        "type": "barchart",
        "gridPos": {"x": 12, "y": 25, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
            "legendFormat": "{{status_code}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "red"}
              ]
            }
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "200"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "500"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "502"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
            {"matcher": {"id": "byRegexp", "options": "/4../"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
          ]
        },
        "options": {
          "orientation": "vertical",
          "showValue": "auto",
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 12,
        "title": "Infrastructure CPU Usage",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 33, "w": 8, "h": 7},
        "targets": [
          {
            "expr": "(1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) by (instance)) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 13,
        "title": "Infrastructure Memory Usage",
        "type": "timeseries",
        "gridPos": {"x": 8, "y": 33, "w": 8, "h": 7},
        "targets": [
          {
            "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 14,
        "title": "Infrastructure Disk I/O",
        "type": "timeseries",
        "gridPos": {"x": 16, "y": 33, "w": 8, "h": 7},
        "targets": [
          {
            "expr": "rate(node_disk_read_bytes_total[5m])",
            "legendFormat": "{{instance}} read",
            "refId": "A"
          },
          {
            "expr": "rate(node_disk_written_bytes_total[5m])",
            "legendFormat": "{{instance}} write",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 15,
        "title": "Redis Memory Usage %",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "(redis_memory_used_bytes / redis_memory_max_bytes) * 100",
            "legendFormat": "Memory",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 85, "color": "orange"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 16,
        "title": "Redis Command Rate",
        "type": "stat",
        "gridPos": {"x": 4, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "rate(redis_commands_processed_total[1m])",
            "legendFormat": "cmds/s",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "cps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "blue"},
                {"value": 100, "color": "green"},
                {"value": 5000, "color": "yellow"},
                {"value": 10000, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 17,
        "title": "Redis Cache Hit Rate",
        "type": "stat",
        "gridPos": {"x": 8, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "(redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)) * 100",
            "legendFormat": "Hit Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value"
        }
      },
      {
        "id": 18,
        "title": "Alert Count (last 1h)",
        "type": "stat",
        "gridPos": {"x": 12, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\"})",
            "legendFormat": "Firing",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 3, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        }
      },
      {
        "id": 19,
        "title": "Container Restarts (last 30m)",
        "type": "stat",
        "gridPos": {"x": 16, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "sum(increase(kube_pod_container_status_restarts_total[30m]) or vector(0))",
            "legendFormat": "Restarts",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        }
      },
      {
        "id": 20,
        "title": "Social Publish — Success Rate",
        "type": "stat",
        "gridPos": {"x": 20, "y": 40, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(render_social_publish_success_total[15m])) / sum(rate(render_social_publish_total[15m])) * 100 or vector(100)",
            "legendFormat": "Success",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 90, "color": "yellow"},
                {"value": 99, "color": "green"}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background"
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "query",
          "label": "Environment",
          "query": "label_values(up, environment)",
          "multi": true,
          "includeAll": true,
          "current": {"text": "All", "value": "$__all"}
        },
        {
          "name": "service",
          "type": "query",
          "label": "Service",
          "query": "label_values(http_requests_total, service)",
          "multi": true,
          "includeAll": true,
          "current": {"text": "All", "value": "$__all"}
        }
      ]
    }
  }
}
