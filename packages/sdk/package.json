{
  "name": "@lazynext/sdk",
  "version": "0.1.0",
  "description": "Typed REST client for the Lazynext public API.",
  "license": "MIT",
  "author": "Lazynext Contributors",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://lazynext.com/docs/api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lazynext-Platform/Lazynext.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Lazynext-Platform/Lazynext/issues"
  },
  "keywords": [
    "lazynext",
    "decisions",
    "rest",
    "api-client",
    "sdk"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "publish:dry": "npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
