{
  "name": "@lazynext/api-client",
  "description": "TypeScript API client for Lazynext REST gateway — health, editor, timeline, projects, AI, and admin endpoints",
"version": "0.1.0",
"private": true,
"packageManager": "bun@1.3.14",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth-middleware": "./src/auth-middleware.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/express": "^5.0.0"
  }
}
