{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "lib/inngest/functions/index.ts",
    "components/ui/EmptyStates.tsx",
    "components/ui/ToastProvider.tsx",
    "components/canvas/panels/CanvasContextMenu.tsx",
    "lib/ai/prompts.ts",
    "lib/db/client.ts",
    "lib/email/templates/index.tsx",
