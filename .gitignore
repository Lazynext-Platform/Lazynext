# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# asdf version management
.tool-versions

node_modules
.cursorignore
.turbo

.env*
!*.env.example

# cursor
bun.lockb

# content-collections
.content-collections

# Twiggy
.cursor/

.open-next

target/

.cargo-tools/

rust-migration-notes.md
.DS_Store
.next

# Testing & Logs
test-results/
playwright-report/
blob-report/
playwright/.cache/
*.log
*.tsbuildinfo

# Python
__pycache__/
venv/
.pytest_cache/

# Terraform
terraform/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/.terraform.lock.hcl
terraform/**/terraform.tfvars
# Track example tfvars only
!terraform/**/terraform.tfvars.example

# Render Service outputs
services/render-service/outputs/**/.terraform/
.terraform/

# Sensitive config files — do NOT commit real secrets
# Template files env.yaml, web.json, db.json are safe to track
# (they contain REPLACE_ placeholders, not real credentials)
*.production.yaml
*.production.json

# Claude Code
.claude/

# JetBrains IDE
.idea/

# VS Code workspace settings
.vscode/

# Vim
*.swp
*.swo

# Merge conflict artifacts
*.orig

# Ansible
*.retry
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.backup
infra/terraform/.terraform.lock.hcl
infra/terraform/**/*.tfvars
!infra/terraform/**/terraform.tfvars.example

