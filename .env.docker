# ── Docker Compose Environment Defaults ──────────────────────────
# These variables are read by docker-compose.yml when no .env exists.
# Copy to .env and customize: cp .env.docker .env

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://${DB_USER:-lazynext}:${DB_PASSWORD:-changeme}@db:5432/lazynext
DB_USER=lazynext
DB_PASSWORD=changeme
POSTGRES_USER=lazynext
POSTGRES_PASSWORD=${DB_PASSWORD:-changeme}
POSTGRES_DB=lazynext

# ── Auth ─────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=local-dev-secret-change-in-production-64chars
BETTER_AUTH_URL=http://localhost:3000

# ── Redis / Upstash ──────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://redis-proxy:80
UPSTASH_REDIS_REST_TOKEN=${UPSTASH_REDIS_REST_TOKEN:-dev_token}

# ── Service URLs (internal Docker network) ───────────────────────────────
RENDER_SERVICE_URL=http://render-service:8003
GENERATIVE_STUDIO_URL=http://generative-studio:8001
PRE_PROCESSING_URL=http://pre-processing:8000
AI_AGENTS_URL=http://ai-agents:8002
COLLAB_SERVER_URL=http://collab-server:8004
ANALYTICS_SERVICE_URL=http://analytics-service:8006

# ── Public URLs (browser-accessible) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PREPROCESSING_URL=http://localhost:8000
NEXT_PUBLIC_GENERATIVE_STUDIO_URL=http://localhost:8001
NEXT_PUBLIC_AI_AGENTS_URL=http://localhost:8002
NEXT_PUBLIC_RENDER_SERVICE_URL=http://localhost:8003

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
MEDIA_BUCKET=lazynext-media-dev

# ── AI Providers (leave empty for local/dev mode) ────────────────────────
LLM_PROVIDER=gemini

# ── Analytics ────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_dev
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Payments (optional in dev) ───────────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
NEXT_PUBLIC_DODO_PRO_PRICE_ID=
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID=

# ── Email (optional in dev) ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Lazynext <no-reply@lazynext.com>"

# ── External APIs (optional in dev) ──────────────────────────────────────
FREESOUND_CLIENT_ID=
FREESOUND_API_KEY=
MARBLE_WORKSPACE_KEY=mock_marble_key
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# ── Docker-specific ──────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=lazynext
COMPOSE_FILE=docker-compose.yml
GEMINI_API_KEY=YourGeminiKeyHere
