# Auto-detect text files and normalize line endings
* text=auto

# Lock files — treat as binary to avoid merge conflicts
Cargo.lock binary
bun.lock binary
bun.lockb binary

# WASM binaries
*.wasm binary
*.wasm.gz binary

# Generated code
*.gen.ts linguist-generated=true

# SQL migration files
*.sql diff=sql

# Shell scripts
*.sh text eol=lf

# Terraform
*.tf text eol=lf
*.tfvars text eol=lf

# Python
*.py text eol=lf

# Rust
*.rs text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
