# Terraform Dev Environment
# Copy this to terraform.tfvars and fill in the values.

project_id  = "vertexaiopencode"
region      = "us-central1"
environment = "dev"

db_password = "CHANGE_ME_TO_A_STRONG_PASSWORD"
db_tier     = "db-f1-micro"

app_domain = "https://lazynext.ai"

# Optional — leave empty to use mock/demo mode
replicate_api_token = ""
elevenlabs_api_key  = ""
