# Lazynext Environment Variables
# Copy to .env.local and fill in actual values for local development.

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lazynext
DB_USER=lazynext
DB_PASSWORD=changeme

# ── Authentication ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_string
BETTER_AUTH_URL=http://localhost:3000

# ── Redis / Upstash ──────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=mock_upstash_token

# ── PostHog Analytics ────────────────────────────────────────────────────

# ── Stripe Payments ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YourKeyHere
STRIPE_WEBHOOK_SECRET=whsec_YourKeyHere
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YourKeyHere
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_placeholder
NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=price_studio_placeholder

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_YourKeyHere

# ── Microservices URLs ───────────────────────────────────────────────────
NEXT_PUBLIC_PREPROCESSING_URL=http://localhost:8000
NEXT_PUBLIC_GENERATIVE_STUDIO_URL=http://localhost:8001
NEXT_PUBLIC_AI_AGENTS_URL=http://localhost:8002
NEXT_PUBLIC_RENDER_SERVICE_URL=http://localhost:8003

# ── AI Provider Keys (optional — falls back to mock) ────────────────────
LLM_PROVIDER=ollama               # openai | anthropic | gemini | ollama
OPENAI_API_KEY=sk-YourKeyHere
ANTHROPIC_API_KEY=sk-ant-YourKeyHere
GEMINI_API_KEY=YourGeminiKeyHere
REPLICATE_API_TOKEN=r8_YourKeyHere

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local            # local | azure
MEDIA_BUCKET=media
AZURE_STORAGE_ACCOUNT=lazynextmediadev

# ── Marble CMS ───────────────────────────────────────────────────────────
MARBLE_WORKSPACE_KEY=mock_marble_key
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# ── Freesound ────────────────────────────────────────────────────────────
FREESOUND_CLIENT_ID=mock_freesound_client
FREESOUND_API_KEY=mock_freesound_key

# ── Deployment ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── API Gateway ──────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/
API_GATEWAY_URL=http://localhost:8005
LAZYNEXT_WEBHOOK_URL=
LAZYNEXT_MCP_API_KEY=default_test_key

# ── Observability ────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=lazynext-pre-processing
GRAFANA_ADMIN_PASSWORD=admin
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
