# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding/create-workspace
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/create-workspace

# Neon Postgres
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/lazynext?sslmode=require

# AI — Groq (primary)
GROQ_API_KEY=gsk_xxxxx

# AI — Together (fallback)
TOGETHER_API_KEY=xxxxx

# Payments — Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Payments — Stripe (International)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_STARTER_MONTHLY_ID=price_xxxxx
STRIPE_STARTER_YEARLY_ID=price_xxxxx
STRIPE_PRO_MONTHLY_ID=price_xxxxx
STRIPE_PRO_YEARLY_ID=price_xxxxx
STRIPE_BUSINESS_MONTHLY_ID=price_xxxxx
STRIPE_BUSINESS_YEARLY_ID=price_xxxxx

# Email — Resend
RESEND_API_KEY=re_xxxxx

# Background Jobs — Inngest
INNGEST_EVENT_KEY=xxxxx
INNGEST_SIGNING_KEY=signkey-xxxxx

# Monitoring (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
