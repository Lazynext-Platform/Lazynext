# Lazynext Environment Variables
# Copy to .env.local and fill in actual values for local development.

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lazynext
DB_USER=lazynext
DB_PASSWORD=changeme

# ── Authentication ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_string
BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXT_PUBLIC_SITE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple OAuth ──────────────────────────────────────────────────────────
# Create at: https://developer.apple.com/account/resources/identifiers/list
# Authorized redirect URI: <NEXT_PUBLIC_SITE_URL>/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Microsoft OAuth (Personal + Work/School) ─────────────────────────────
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Authorized redirect URI: <NEXT_PUBLIC_SITE_URL>/api/auth/callback/microsoft
# Set MICROSOFT_TENANT_ID to "common" for personal + work accounts,
# or your Azure AD tenant ID for enterprise-only.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Azure AD / Entra ID (Enterprise SSO) ─────────────────────────────────
# Create at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Authorized redirect URI: <NEXT_PUBLIC_SITE_URL>/api/auth/callback/azureAd
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── OIDC SSO (Enterprise SAML/OIDC Bridge) ──────────────────────────────
# Comma-separated list of domain names allowed for enterprise SSO.
# Example: lazynext.com,acme-corp.com
OIDC_ALLOWED_DOMAINS=

# ── Redis / Upstash ──────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=mock_upstash_token

# ── PostHog Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_dev
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── All 10 Analytics Providers ───────────────────────────────────────────
# PostHog (wired above) | Clarity (free, session recordings)
# NEXT_PUBLIC_CLARITY_ID=
# Plausible (privacy-first) | GA4 (traffic)
# PLAUSIBLE_API_KEY=          PLAUSIBLE_URL=
# GA4_MEASUREMENT_ID=         GA4_API_SECRET=
# Mixpanel (20M events free) | Amplitude (50K MTUs free)
# NEXT_PUBLIC_MIXPANEL_TOKEN= MIXPANEL_API_SECRET=
# NEXT_PUBLIC_AMPLITUDE_API_KEY=
# Umami (:8093) | Matomo (:8094) | OpenPanel (:8095) | Countly (:8096)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=   NEXT_PUBLIC_UMAMI_URL=http://localhost:8093
# NEXT_PUBLIC_MATOMO_SITE_ID=     NEXT_PUBLIC_MATOMO_URL=http://localhost:8094
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID=NEXT_PUBLIC_OPENPANEL_URL=http://localhost:8095
# NEXT_PUBLIC_COUNTLY_APP_KEY=    NEXT_PUBLIC_COUNTLY_URL=http://localhost:8096

# ── Dodo Payments ────────────────────────────────────────────────────────
DODO_API_KEY=dp_test_YourKeyHere
DODO_WEBHOOK_SECRET=dwhsec_YourKeyHere
NEXT_PUBLIC_DODO_PRO_PRICE_ID=pro_monthly
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID=studio_monthly

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_YourKeyHere
EMAIL_FROM="Lazynext <no-reply@lazynext.com>"

# ── Desktop App URL (for OAuth redirect) ─────────────────────────────────
NEXT_PUBLIC_DESKTOP_URL=http://localhost:1420

# ── Mobile App URL (for OAuth deep link) ─────────────────────────────────
NEXT_PUBLIC_MOBILE_URL=lazynext://

# ── Microservices URLs ───────────────────────────────────────────────────
NEXT_PUBLIC_PREPROCESSING_URL=http://localhost:8000
NEXT_PUBLIC_GENERATIVE_STUDIO_URL=http://localhost:8001
NEXT_PUBLIC_AI_AGENTS_URL=http://localhost:8002
NEXT_PUBLIC_RENDER_SERVICE_URL=http://localhost:8003

# ── AI Provider Keys (optional — falls back to mock) ────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=YourGeminiKeyHere

# ── Video AI — Modal GPU Compute ──────────────────────────────────────
# Uses Modal SD Pipeline for GPU-accelerated text-to-video.
# $30/mo free credits, 35s generation, 5 concurrent.
# MODAL_API_KEY=           # required for GPU inference

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
MEDIA_BUCKET=media

# ── Marble CMS ───────────────────────────────────────────────────────────
MARBLE_WORKSPACE_KEY=mock_marble_key
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# ── Freesound ────────────────────────────────────────────────────────────
FREESOUND_CLIENT_ID=mock_freesound_client
FREESOUND_API_KEY=mock_freesound_key

# ── Deployment ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── API Gateway ──────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/
API_GATEWAY_URL=http://localhost:8005
LAZYNEXT_WEBHOOK_URL=
LAZYNEXT_MCP_API_KEY=default_test_key

# ── Social Publish ────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_PUBLISH_URL=http://localhost:8007
# Public HTTPS base URL where rendered media is served. Required for Instagram
# publishing, whose Graph API downloads media from a public URL (not file://).
PUBLIC_MEDIA_BASE_URL=

# ── Collaboration ──────────────────────────────────────────────────────────
# WebSocket URL for the CRDT collab server. Set to the deployed FQDN in
# production (e.g. wss://collab.lazynext.com/ws).
NEXT_PUBLIC_SYNC_SERVER_URL=ws://localhost:8004/ws

# ── Observability ────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=lazynext-pre-processing
GRAFANA_ADMIN_PASSWORD=admin
SLACK_WEBHOOK_URL=
GRAFANA_ONCALL_INTEGRATION_URL=

# ── CAPTCHA / Anti-Bot Verification ──────────────────────────────────────
# Cloudflare Turnstile — invisible CAPTCHA for web, mobile, and extension UIs.
# Get site key + secret key at: https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (NEXT_PUBLIC_ prefix), secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Proof-of-Work difficulty (leading zero bits, 20 ≈ 1s on modern CPU).
# Increase for production (24+), decrease for low-power devices.
POW_DIFFICULTY=20

# Set to "true" to bypass all CAPTCHA checks (development only).
CAPTCHA_DISABLED=false
