# Lazynext Environment Variables
# Copy to .env.local and fill in actual values for local development.

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lazynext
DB_USER=lazynext
DB_PASSWORD=changeme

# ── Authentication ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_string
BETTER_AUTH_URL=http://localhost:3000

# ── Redis / Upstash ──────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=mock_upstash_token

# ── PostHog Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_dev
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── All 10 Analytics Providers ───────────────────────────────────────────
# PostHog (wired above) | Clarity (free, session recordings)
# NEXT_PUBLIC_CLARITY_ID=
# Plausible (privacy-first) | GA4 (traffic)
# PLAUSIBLE_API_KEY=          PLAUSIBLE_URL=
# GA4_MEASUREMENT_ID=         GA4_API_SECRET=
# Mixpanel (20M events free) | Amplitude (50K MTUs free)
# NEXT_PUBLIC_MIXPANEL_TOKEN= MIXPANEL_API_SECRET=
# NEXT_PUBLIC_AMPLITUDE_API_KEY=
# Umami (:8093) | Matomo (:8094) | OpenPanel (:8095) | Countly (:8096)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=   NEXT_PUBLIC_UMAMI_URL=http://localhost:8093
# NEXT_PUBLIC_MATOMO_SITE_ID=     NEXT_PUBLIC_MATOMO_URL=http://localhost:8094
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID=NEXT_PUBLIC_OPENPANEL_URL=http://localhost:8095
# NEXT_PUBLIC_COUNTLY_APP_KEY=    NEXT_PUBLIC_COUNTLY_URL=http://localhost:8096

# ── Dodo Payments ────────────────────────────────────────────────────────
DODO_API_KEY=dp_test_YourKeyHere
DODO_WEBHOOK_SECRET=dwhsec_YourKeyHere
NEXT_PUBLIC_DODO_PRO_PRICE_ID=pro_monthly
NEXT_PUBLIC_DODO_STUDIO_PRICE_ID=studio_monthly

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=re_YourKeyHere
EMAIL_FROM="Lazynext <no-reply@lazynext.com>"

# ── Microservices URLs ───────────────────────────────────────────────────
NEXT_PUBLIC_PREPROCESSING_URL=http://localhost:8000
NEXT_PUBLIC_GENERATIVE_STUDIO_URL=http://localhost:8001
NEXT_PUBLIC_AI_AGENTS_URL=http://localhost:8002
NEXT_PUBLIC_RENDER_SERVICE_URL=http://localhost:8003

# ── AI Provider Keys (optional — falls back to mock) ────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=YourGeminiKeyHere

# ── Video AI — Hugging Face Spaces (free, no API key) ──────────────
# Uses HF Spaces + Wan 2.1 for GPU-accelerated text-to-video.
# Completely free — runs on shared HF GPU infrastructure.
# HF_VIDEO_SPACE=Wan-AI/Wan2.1
# HF_TOKEN=                # optional, removes rate limits

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local            # local | azure
MEDIA_BUCKET=media
AZURE_STORAGE_ACCOUNT=lazynextmediadev

# ── Marble CMS ───────────────────────────────────────────────────────────
MARBLE_WORKSPACE_KEY=mock_marble_key
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# ── Freesound ────────────────────────────────────────────────────────────
FREESOUND_CLIENT_ID=mock_freesound_client
FREESOUND_API_KEY=mock_freesound_key

# ── Deployment ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── API Gateway ──────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/
API_GATEWAY_URL=http://localhost:8005
LAZYNEXT_WEBHOOK_URL=
LAZYNEXT_MCP_API_KEY=default_test_key

# ── Social Publish ────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_PUBLISH_URL=http://localhost:8007
# Public HTTPS base URL where rendered media is served. Required for Instagram
# publishing, whose Graph API downloads media from a public URL (not file://).
PUBLIC_MEDIA_BASE_URL=

# ── Collaboration ──────────────────────────────────────────────────────────
# WebSocket URL for the CRDT collab server. Set to the deployed FQDN in
# production (e.g. wss://lazynext-collab-production.xyz.azurecontainerapps.io/ws).
NEXT_PUBLIC_SYNC_SERVER_URL=ws://localhost:8004/ws

# ── Observability ────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=lazynext-pre-processing
GRAFANA_ADMIN_PASSWORD=admin
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
