# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhxxxxxxxx

# AI — Groq (primary)
GROQ_API_KEY=gsk_xxxxx

# AI — Together (fallback)
TOGETHER_API_KEY=xxxxx

# Payments — Gumroad
# Webhook secret: random string you pick. Used as the last path segment of
# your Gumroad "Resource Subscription" / "Ping" URL:
#   https://<app>/api/v1/webhooks/gumroad/<GUMROAD_WEBHOOK_SECRET>
GUMROAD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Gumroad product permalinks (create subscription products in the Gumroad
# dashboard, set them to recurring, then copy the product URL).
# The NEXT_PUBLIC_ variants are read by the pricing page for direct links.
# The server-side variants (without NEXT_PUBLIC_) are read by the checkout
# API when a workspace is authenticated. Either is fine; set whichever
# matches your deploy surface.
NEXT_PUBLIC_GUMROAD_STARTER_MONTHLY_URL=https://yourstore.gumroad.com/l/starter-monthly
NEXT_PUBLIC_GUMROAD_STARTER_ANNUAL_URL=https://yourstore.gumroad.com/l/starter-yearly
NEXT_PUBLIC_GUMROAD_PRO_MONTHLY_URL=https://yourstore.gumroad.com/l/pro-monthly
NEXT_PUBLIC_GUMROAD_PRO_ANNUAL_URL=https://yourstore.gumroad.com/l/pro-yearly
NEXT_PUBLIC_GUMROAD_BUSINESS_MONTHLY_URL=https://yourstore.gumroad.com/l/business-monthly
NEXT_PUBLIC_GUMROAD_BUSINESS_ANNUAL_URL=https://yourstore.gumroad.com/l/business-yearly

# Email — Resend
RESEND_API_KEY=re_xxxxx

# Background Jobs — Inngest
INNGEST_EVENT_KEY=xxxxx
INNGEST_SIGNING_KEY=signkey-xxxxx

# Monitoring (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
